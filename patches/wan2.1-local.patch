+        v2 = v.unflatten(0, (b, lk)).transpose(1, 2)
+        x = F.scaled_dot_product_attention(
+            q2, k2, v2,
+            dropout_p=dropout_p if dropout_p else 0.0,
+            is_causal=causal,
+            scale=softmax_scale,
+        ).transpose(1, 2)  # (b, lq, num_heads, head_dim)
 
     # output
     return x.type(out_dtype)
